#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'

DOCKER="${NEWAPI_DEPLOY_DOCKER:-docker}"
NEWAPI_AB="${NEWAPI_DEPLOY_AB_COMMAND:-newapi-ab}"
CURL="${NEWAPI_DEPLOY_CURL:-curl}"
JQ="${NEWAPI_DEPLOY_JQ:-jq}"
COMPOSE_DIR="${NEWAPI_DEPLOY_COMPOSE_DIR:-/srv/new-api-ai}"
COMPOSE_FILE="${NEWAPI_DEPLOY_COMPOSE_FILE:-${COMPOSE_DIR}/docker-compose.yml}"
STATE_DIR="${NEWAPI_DEPLOY_STATE_DIR:-${COMPOSE_DIR}/.rtoc-release}"
CURRENT_FILE="${STATE_DIR}/current.env"
PREPARED_FILE="${STATE_DIR}/prepared.env"
EVIDENCE_FILE="${STATE_DIR}/evidence.jsonl"
LOCK_FILE="${NEWAPI_DEPLOY_LOCK_FILE:-/run/lock/rtoc-newapi-deploy.lock}"
IMAGE_REPOSITORY="${NEWAPI_DEPLOY_IMAGE_REPOSITORY:-ghcr.io/hechuyi/new-api-rtoc}"
STABLE_URL="${NEWAPI_DEPLOY_STABLE_URL:-http://127.0.0.1:3010/api/status}"
PUBLIC_URL="${NEWAPI_DEPLOY_PUBLIC_URL:-https://api.rtoc.cc/api/status}"
HEALTH_ATTEMPTS="${NEWAPI_DEPLOY_HEALTH_ATTEMPTS:-30}"
SLEEP_SECONDS="${NEWAPI_DEPLOY_SLEEP_SECONDS:-1}"

die() {
    printf 'error: %s\n' "$*" >&2
    exit 1
}

validate_slot() {
    case "$1" in
        a | b) ;;
        *) die "invalid slot: $1" ;;
    esac
}

other_slot() {
    case "$1" in
        a) printf 'b\n' ;;
        b) printf 'a\n' ;;
        *) die "invalid slot: $1" ;;
    esac
}

slot_service() {
    validate_slot "$1"
    printf 'new-api-%s\n' "$1"
}

slot_container() {
    validate_slot "$1"
    printf 'new-api-ai-%s\n' "$1"
}

slot_url() {
    case "$1" in
        a) printf '%s\n' "${NEWAPI_DEPLOY_SLOT_A_URL:-http://127.0.0.1:3012/api/status}" ;;
        b) printf '%s\n' "${NEWAPI_DEPLOY_SLOT_B_URL:-http://127.0.0.1:3013/api/status}" ;;
        *) die "invalid slot: $1" ;;
    esac
}

validate_release() {
    [[ "$1" =~ ^[A-Za-z0-9._:@/+%-]+$ ]] \
        || die "invalid release identifier"
}

validate_revision() {
    [[ "$1" =~ ^[0-9a-f]{40}$ ]] || die "invalid source revision"
}

validate_image_id() {
    [[ "$1" =~ ^sha256:[0-9a-f]{64}$ ]] || die "invalid image ID"
}

validate_candidate_image() {
    local escaped_repository
    escaped_repository="$(
        printf '%s' "${IMAGE_REPOSITORY}" \
            | sed 's/[][\\.^$*+?{}()|/]/\\&/g'
    )"
    [[ "$1" =~ ^${escaped_repository}@sha256:[0-9a-f]{64}$ ]] \
        || die "candidate image must be an immutable ${IMAGE_REPOSITORY}@sha256 digest"
}

require_commands() {
    command -v "${DOCKER}" >/dev/null || die "docker command not found"
    command -v "${NEWAPI_AB}" >/dev/null || die "newapi-ab command not found"
    command -v "${CURL}" >/dev/null || die "curl command not found"
    command -v "${JQ}" >/dev/null || die "jq command not found"
    command -v flock >/dev/null || die "flock command not found"
}

runtime_status() {
    "${NEWAPI_AB}" status
}

slot_field() {
    local status="$1"
    local slot="$2"
    local field="$3"
    printf '%s\n' "${status}" | awk -v wanted_slot="${slot}" -v wanted_field="${field}" '
        $1 == wanted_slot {
            for (i = 2; i <= NF; i++) {
                split($i, pair, "=")
                if (pair[1] == wanted_field) {
                    print pair[2]
                    found = 1
                    exit
                }
            }
        }
        END {
            if (!found) {
                exit 1
            }
        }
    '
}

active_slot_from_status() {
    local status="$1"
    local a_weight b_weight a_status b_status
    a_weight="$(slot_field "${status}" a weight)"
    b_weight="$(slot_field "${status}" b weight)"
    a_status="$(slot_field "${status}" a status)"
    b_status="$(slot_field "${status}" b status)"
    [[ "${a_status}" = "UP" && "${b_status}" = "UP" ]] \
        || die "both NewAPI slots must be UP"
    if [[ "${a_weight}" = "100" && "${b_weight}" = "0" ]]; then
        printf 'a\n'
    elif [[ "${a_weight}" = "0" && "${b_weight}" = "100" ]]; then
        printf 'b\n'
    else
        die "expected exactly one weight-100 slot and one weight-0 slot"
    fi
}

container_field() {
    local slot="$1"
    local format="$2"
    "${DOCKER}" inspect "$(slot_container "${slot}")" --format "${format}"
}

container_image_id() {
    container_field "$1" '{{.Image}}'
}

container_image_ref() {
    container_field "$1" '{{.Config.Image}}'
}

container_revision() {
    container_field "$1" '{{index .Config.Labels "org.opencontainers.image.revision"}}'
}

container_running() {
    [[ "$(container_field "$1" '{{.State.Running}}' 2>/dev/null || true)" = "true" ]]
}

wait_url() {
    local url="$1"
    local attempt
    for attempt in $(seq 1 "${HEALTH_ATTEMPTS}"); do
        if "${CURL}" -fsS --max-time 10 -o /dev/null "${url}"; then
            return 0
        fi
        sleep "${SLEEP_SECONDS}"
    done
    return 1
}

wait_slot() {
    local slot="$1"
    container_running "${slot}" && wait_url "$(slot_url "${slot}")"
}

wait_runtime_slot_up() {
    local slot="$1"
    local attempt status
    for attempt in $(seq 1 "${HEALTH_ATTEMPTS}"); do
        status="$(runtime_status)"
        if [[ "$(slot_field "${status}" "${slot}" status 2>/dev/null || true)" = "UP" ]]; then
            return 0
        fi
        sleep "${SLEEP_SECONDS}"
    done
    return 1
}

set_active_slot() {
    validate_slot "$1"
    "${NEWAPI_AB}" "active-$1"
}

atomic_write() {
    local destination="$1"
    local temporary
    mkdir -p "$(dirname "${destination}")"
    temporary="$(mktemp "${destination}.tmp.XXXXXX")"
    cat >"${temporary}"
    chmod 600 "${temporary}"
    mv -f "${temporary}" "${destination}"
}

write_state_file() {
    local destination="$1"
    shift
    local key value
    {
        while [[ "$#" -gt 0 ]]; do
            key="$1"
            value="$2"
            shift 2
            [[ "${key}" =~ ^[A-Z0-9_]+$ ]] || die "invalid state key"
            [[ "${value}" != *$'\n'* && "${value}" != *$'\r'* ]] \
                || die "invalid state value"
            printf '%s=%s\n' "${key}" "${value}"
        done
    } | atomic_write "${destination}"
}

load_current() {
    [[ -f "${CURRENT_FILE}" ]] || die "current release state is not initialized"
    unset CURRENT_ACTIVE_SLOT CURRENT_ACTIVE_RELEASE CURRENT_ACTIVE_IMAGE
    unset CURRENT_ACTIVE_IMAGE_ID CURRENT_ACTIVE_REVISION
    unset ROLLBACK_SLOT ROLLBACK_RELEASE ROLLBACK_IMAGE
    unset ROLLBACK_IMAGE_ID ROLLBACK_REVISION UPDATED_AT
    # shellcheck source=/dev/null
    source "${CURRENT_FILE}"
    validate_slot "${CURRENT_ACTIVE_SLOT:-}"
    validate_slot "${ROLLBACK_SLOT:-}"
    validate_release "${CURRENT_ACTIVE_RELEASE:-}"
    validate_release "${ROLLBACK_RELEASE:-}"
    validate_image_id "${CURRENT_ACTIVE_IMAGE_ID:-}"
    validate_image_id "${ROLLBACK_IMAGE_ID:-}"
    validate_revision "${CURRENT_ACTIVE_REVISION:-}"
    validate_revision "${ROLLBACK_REVISION:-}"
}

load_prepared() {
    [[ -f "${PREPARED_FILE}" ]] || die "no prepared release"
    unset PREPARED_SLOT PREPARED_IMAGE PREPARED_IMAGE_ID PREPARED_REVISION
    unset PREPARED_RELEASE SOURCE_ACTIVE_SLOT SOURCE_ACTIVE_IMAGE_ID PREPARED_AT
    # shellcheck source=/dev/null
    source "${PREPARED_FILE}"
    validate_slot "${PREPARED_SLOT:-}"
    validate_candidate_image "${PREPARED_IMAGE:-}"
    validate_image_id "${PREPARED_IMAGE_ID:-}"
    validate_revision "${PREPARED_REVISION:-}"
    validate_release "${PREPARED_RELEASE:-}"
    validate_slot "${SOURCE_ACTIVE_SLOT:-}"
    validate_image_id "${SOURCE_ACTIVE_IMAGE_ID:-}"
}

bootstrap_current_state() {
    local active="$1"
    local inactive
    inactive="$(other_slot "${active}")"
    if [[ -f "${CURRENT_FILE}" ]]; then
        load_current
        [[ "${CURRENT_ACTIVE_SLOT}" = "${active}" ]] \
            || die "runtime active slot does not match current state"
        return
    fi
    local active_revision inactive_revision
    active_revision="$(container_revision "${active}")"
    inactive_revision="$(container_revision "${inactive}")"
    validate_revision "${active_revision}"
    validate_revision "${inactive_revision}"
    write_state_file "${CURRENT_FILE}" \
        CURRENT_ACTIVE_SLOT "${active}" \
        CURRENT_ACTIVE_RELEASE "bootstrap-${active_revision:0:12}" \
        CURRENT_ACTIVE_IMAGE "$(container_image_ref "${active}")" \
        CURRENT_ACTIVE_IMAGE_ID "$(container_image_id "${active}")" \
        CURRENT_ACTIVE_REVISION "${active_revision}" \
        ROLLBACK_SLOT "${inactive}" \
        ROLLBACK_RELEASE "bootstrap-${inactive_revision:0:12}" \
        ROLLBACK_IMAGE "$(container_image_ref "${inactive}")" \
        ROLLBACK_IMAGE_ID "$(container_image_id "${inactive}")" \
        ROLLBACK_REVISION "${inactive_revision}" \
        UPDATED_AT "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}

set_compose_service_image() {
    local service="$1"
    local image="$2"
    local temporary
    temporary="$(mktemp "${COMPOSE_FILE}.tmp.XXXXXX")"
    if ! awk -v wanted="${service}" -v image="${image}" '
        $0 == "  " wanted ":" {
            inside = 1
            print
            next
        }
        inside && /^  [^ ]/ {
            inside = 0
        }
        inside && /^    image: / {
            print "    image: " image
            changed = 1
            next
        }
        { print }
        END {
            if (!changed) {
                exit 42
            }
        }
    ' "${COMPOSE_FILE}" >"${temporary}"; then
        rm -f "${temporary}"
        die "compose service image was not updated"
    fi
    chmod --reference="${COMPOSE_FILE}" "${temporary}" 2>/dev/null || true
    mv -f "${temporary}" "${COMPOSE_FILE}"
}

start_slot() {
    local slot="$1"
    "${DOCKER}" compose -f "${COMPOSE_FILE}" up -d --no-deps --pull never \
        "$(slot_service "${slot}")"
}

verify_image() {
    local image="$1"
    local expected_digest="$2"
    local expected_revision="$3"
    local actual_id actual_revision platform image_digest
    image_digest="${image##*@}"
    [[ "${expected_digest}" = "${image_digest}" ]] \
        || die "candidate image digest does not match immutable image reference"
    actual_id="$("${DOCKER}" image inspect "${image}" --format '{{.Id}}')"
    actual_revision="$(
        "${DOCKER}" image inspect "${image}" \
            --format '{{index .Config.Labels "org.opencontainers.image.revision"}}'
    )"
    platform="$(
        "${DOCKER}" image inspect "${image}" --format '{{.Os}}/{{.Architecture}}'
    )"
    validate_image_id "${actual_id}"
    [[ "${actual_revision}" = "${expected_revision}" ]] \
        || die "candidate revision label does not match expected revision"
    [[ "${platform}" = "linux/amd64" ]] \
        || die "candidate platform must be linux/amd64"
    printf '%s\n' "${actual_id}"
}

record_evidence() {
    local operation="$1"
    local result="$2"
    local release="$3"
    mkdir -p "${STATE_DIR}"
    "${JQ}" -nc \
        --arg recorded_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        --arg operation "${operation}" \
        --arg result "${result}" \
        --arg release "${release}" \
        '{recorded_at:$recorded_at,operation:$operation,result:$result,release:$release}' \
        >>"${EVIDENCE_FILE}"
    chmod 600 "${EVIDENCE_FILE}"
}

show_status() {
    local status active inactive a_weight b_weight
    local a_status b_status
    status="$(runtime_status)"
    active="$(active_slot_from_status "${status}")"
    inactive="$(other_slot "${active}")"
    a_weight="$(slot_field "${status}" a weight)"
    b_weight="$(slot_field "${status}" b weight)"
    a_status="$(slot_field "${status}" a status)"
    b_status="$(slot_field "${status}" b status)"

    local prepared_release="none" prepared_slot=""
    if [[ -f "${PREPARED_FILE}" ]]; then
        load_prepared
        prepared_release="${PREPARED_RELEASE}"
        prepared_slot="${PREPARED_SLOT}"
    fi

    "${JQ}" -n \
        --arg active_slot "${active}" \
        --arg inactive_slot "${inactive}" \
        --arg a_status "${a_status}" \
        --arg b_status "${b_status}" \
        --argjson a_weight "${a_weight}" \
        --argjson b_weight "${b_weight}" \
        --arg a_image "$(container_image_ref a)" \
        --arg b_image "$(container_image_ref b)" \
        --arg a_image_id "$(container_image_id a)" \
        --arg b_image_id "$(container_image_id b)" \
        --arg prepared_release "${prepared_release}" \
        --arg prepared_slot "${prepared_slot}" \
        '{
            ok:true,
            operation:"status",
            active_slot:$active_slot,
            inactive_slot:$inactive_slot,
            prepared_release:$prepared_release,
            prepared_slot:$prepared_slot,
            slots:{
                a:{status:$a_status,weight:$a_weight,image:$a_image,image_id:$a_image_id},
                b:{status:$b_status,weight:$b_weight,image:$b_image,image_id:$b_image_id}
            }
        }'
}

prepare_release() {
    local image="$1"
    local expected_digest="$2"
    local revision="$3"
    local release="$4"
    validate_candidate_image "${image}"
    validate_image_id "${expected_digest}"
    validate_revision "${revision}"
    validate_release "${release}"

    local status active inactive service container old_image backup
    status="$(runtime_status)"
    active="$(active_slot_from_status "${status}")"
    inactive="$(other_slot "${active}")"
    service="$(slot_service "${inactive}")"
    container="$(slot_container "${inactive}")"

    wait_slot "${active}" || die "active slot is not healthy"
    wait_url "${STABLE_URL}" || die "stable endpoint is not healthy"
    bootstrap_current_state "${active}"

    if [[ -f "${PREPARED_FILE}" ]]; then
        load_prepared
        if [[ "${PREPARED_RELEASE}" = "${release}" \
            && "${PREPARED_IMAGE}" = "${image}" \
            && "$(container_image_id "${PREPARED_SLOT}")" = "${PREPARED_IMAGE_ID}" ]]; then
            "${JQ}" -n \
                --arg release "${release}" \
                --arg prepared_slot "${PREPARED_SLOT}" \
                --arg active_slot "${active}" \
                '{ok:true,operation:"prepare",idempotent:true,release:$release,prepared_slot:$prepared_slot,active_slot:$active_slot}'
            return
        fi
        die "another release is already prepared"
    fi

    "${DOCKER}" pull "${image}" >/dev/null
    local actual_image_id
    actual_image_id="$(verify_image "${image}" "${expected_digest}" "${revision}")"

    old_image="$(container_image_ref "${inactive}")"
    mkdir -p "${STATE_DIR}"
    backup="${STATE_DIR}/compose-before-${release}-$(date -u +%Y%m%dT%H%M%SZ).yml"
    cp "${COMPOSE_FILE}" "${backup}"

    if ! {
        set_compose_service_image "${service}" "${image}"
        start_slot "${inactive}" >/dev/null
        [[ "$(container_image_id "${inactive}")" = "${actual_image_id}" ]]
        [[ "$(container_revision "${inactive}")" = "${revision}" ]]
        wait_slot "${inactive}"
        wait_runtime_slot_up "${inactive}"
        [[ "$(active_slot_from_status "$(runtime_status)")" = "${active}" ]]
        wait_url "${STABLE_URL}"
    }; then
        cp "${backup}" "${COMPOSE_FILE}"
        set_compose_service_image "${service}" "${old_image}"
        start_slot "${inactive}" >/dev/null || true
        die "candidate preparation failed; inactive slot restored"
    fi

    write_state_file "${PREPARED_FILE}" \
        PREPARED_SLOT "${inactive}" \
        PREPARED_IMAGE "${image}" \
        PREPARED_IMAGE_ID "${actual_image_id}" \
        PREPARED_REVISION "${revision}" \
        PREPARED_RELEASE "${release}" \
        SOURCE_ACTIVE_SLOT "${active}" \
        SOURCE_ACTIVE_IMAGE_ID "$(container_image_id "${active}")" \
        PREPARED_AT "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    record_evidence prepare pass "${release}"

    "${JQ}" -n \
        --arg release "${release}" \
        --arg prepared_slot "${inactive}" \
        --arg active_slot "${active}" \
        --arg image "${image}" \
        --arg image_digest "${expected_digest}" \
        --arg image_id "${actual_image_id}" \
        '{
            ok:true,
            operation:"prepare",
            release:$release,
            active_slot:$active_slot,
            prepared_slot:$prepared_slot,
            image:$image,
            image_digest:$image_digest,
            image_id:$image_id
        }'
}

cutover_release() {
    local release="$1"
    validate_release "${release}"
    load_current
    load_prepared
    [[ "${PREPARED_RELEASE}" = "${release}" ]] \
        || die "prepared release does not match requested release"

    local status active target previous_image previous_id previous_revision
    status="$(runtime_status)"
    active="$(active_slot_from_status "${status}")"
    target="${PREPARED_SLOT}"
    [[ "${active}" = "${SOURCE_ACTIVE_SLOT}" ]] \
        || die "active slot changed after preparation"
    [[ "${target}" = "$(other_slot "${active}")" ]] \
        || die "prepared slot is not inactive"
    [[ "$(container_image_id "${active}")" = "${SOURCE_ACTIVE_IMAGE_ID}" ]] \
        || die "active image changed after preparation"
    [[ "$(container_image_id "${target}")" = "${PREPARED_IMAGE_ID}" ]] \
        || die "prepared container image changed"
    [[ "$(container_revision "${target}")" = "${PREPARED_REVISION}" ]] \
        || die "prepared container revision changed"
    wait_slot "${target}" || die "prepared slot is not healthy"

    previous_image="$(container_image_ref "${active}")"
    previous_id="$(container_image_id "${active}")"
    previous_revision="$(container_revision "${active}")"

    local restore_required=1
    restore_cutover() {
        local rc=$?
        if [[ "${restore_required}" = "1" ]]; then
            set_active_slot "${active}" >/dev/null 2>&1 || true
            record_evidence cutover failed-restored "${release}" || true
        fi
        exit "${rc}"
    }
    trap restore_cutover ERR INT TERM

    set_active_slot "${target}"
    [[ "$(active_slot_from_status "$(runtime_status)")" = "${target}" ]]
    wait_slot "${target}"
    wait_url "${STABLE_URL}"
    wait_url "${PUBLIC_URL}"

    write_state_file "${CURRENT_FILE}" \
        CURRENT_ACTIVE_SLOT "${target}" \
        CURRENT_ACTIVE_RELEASE "${PREPARED_RELEASE}" \
        CURRENT_ACTIVE_IMAGE "${PREPARED_IMAGE}" \
        CURRENT_ACTIVE_IMAGE_ID "${PREPARED_IMAGE_ID}" \
        CURRENT_ACTIVE_REVISION "${PREPARED_REVISION}" \
        ROLLBACK_SLOT "${active}" \
        ROLLBACK_RELEASE "${CURRENT_ACTIVE_RELEASE}" \
        ROLLBACK_IMAGE "${previous_image}" \
        ROLLBACK_IMAGE_ID "${previous_id}" \
        ROLLBACK_REVISION "${previous_revision}" \
        UPDATED_AT "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    rm -f "${PREPARED_FILE}"
    record_evidence cutover pass "${release}"
    restore_required=0
    trap - ERR INT TERM

    "${JQ}" -n \
        --arg release "${release}" \
        --arg active_slot "${target}" \
        --arg rollback_slot "${active}" \
        '{ok:true,operation:"cutover",release:$release,active_slot:$active_slot,rollback_slot:$rollback_slot}'
}

rollback_release() {
    load_current
    local status active target current_image current_id current_revision
    status="$(runtime_status)"
    active="$(active_slot_from_status "${status}")"
    [[ "${active}" = "${CURRENT_ACTIVE_SLOT}" ]] \
        || die "runtime active slot does not match current state"
    target="${ROLLBACK_SLOT}"
    [[ "${target}" = "$(other_slot "${active}")" ]] \
        || die "rollback slot is not inactive"

    current_image="$(container_image_ref "${active}")"
    current_id="$(container_image_id "${active}")"
    current_revision="$(container_revision "${active}")"

    if [[ "$(container_image_id "${target}" 2>/dev/null || true)" != "${ROLLBACK_IMAGE_ID}" ]]; then
        local service backup
        service="$(slot_service "${target}")"
        "${DOCKER}" image inspect "${ROLLBACK_IMAGE}" --format '{{.Id}}' >/dev/null \
            || "${DOCKER}" pull "${ROLLBACK_IMAGE}" >/dev/null
        [[ "$("${DOCKER}" image inspect "${ROLLBACK_IMAGE}" --format '{{.Id}}')" = "${ROLLBACK_IMAGE_ID}" ]] \
            || die "rollback image ID does not match retained state"
        backup="${STATE_DIR}/compose-before-rollback-$(date -u +%Y%m%dT%H%M%SZ).yml"
        cp "${COMPOSE_FILE}" "${backup}"
        set_compose_service_image "${service}" "${ROLLBACK_IMAGE}"
        if ! start_slot "${target}" >/dev/null || ! wait_slot "${target}"; then
            cp "${backup}" "${COMPOSE_FILE}"
            die "rollback slot reconstruction failed"
        fi
    fi
    [[ "$(container_image_id "${target}")" = "${ROLLBACK_IMAGE_ID}" ]] \
        || die "rollback slot image does not match retained state"
    wait_slot "${target}" || die "rollback slot is not healthy"

    local restore_required=1
    restore_rollback() {
        local rc=$?
        if [[ "${restore_required}" = "1" ]]; then
            set_active_slot "${active}" >/dev/null 2>&1 || true
            record_evidence rollback failed-restored "${ROLLBACK_RELEASE}" || true
        fi
        exit "${rc}"
    }
    trap restore_rollback ERR INT TERM

    set_active_slot "${target}"
    [[ "$(active_slot_from_status "$(runtime_status)")" = "${target}" ]]
    wait_url "${STABLE_URL}"
    wait_url "${PUBLIC_URL}"

    write_state_file "${CURRENT_FILE}" \
        CURRENT_ACTIVE_SLOT "${target}" \
        CURRENT_ACTIVE_RELEASE "${ROLLBACK_RELEASE}" \
        CURRENT_ACTIVE_IMAGE "${ROLLBACK_IMAGE}" \
        CURRENT_ACTIVE_IMAGE_ID "${ROLLBACK_IMAGE_ID}" \
        CURRENT_ACTIVE_REVISION "${ROLLBACK_REVISION}" \
        ROLLBACK_SLOT "${active}" \
        ROLLBACK_RELEASE "${CURRENT_ACTIVE_RELEASE}" \
        ROLLBACK_IMAGE "${current_image}" \
        ROLLBACK_IMAGE_ID "${current_id}" \
        ROLLBACK_REVISION "${current_revision}" \
        UPDATED_AT "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    rm -f "${PREPARED_FILE}"
    record_evidence rollback pass "${ROLLBACK_RELEASE}"
    restore_required=0
    trap - ERR INT TERM

    "${JQ}" -n \
        --arg active_slot "${target}" \
        --arg rollback_slot "${active}" \
        --arg release "${ROLLBACK_RELEASE}" \
        '{ok:true,operation:"rollback",release:$release,active_slot:$active_slot,rollback_slot:$rollback_slot}'
}

run_locked() {
    local operation="$1"
    shift
    mkdir -p "$(dirname "${LOCK_FILE}")" "${STATE_DIR}"
    exec 9>"${LOCK_FILE}"
    flock -n 9 || die "another NewAPI deployment operation is running"
    case "${operation}" in
        prepare) prepare_release "$@" ;;
        cutover) cutover_release "$@" ;;
        rollback) rollback_release "$@" ;;
        *) die "unsupported state-changing operation" ;;
    esac
}

main() {
    require_commands
    [[ -f "${COMPOSE_FILE}" ]] || die "compose file not found: ${COMPOSE_FILE}"
    case "${1:-}" in
        status)
            [[ "$#" -eq 1 ]] || die "usage: status"
            show_status
            ;;
        prepare)
            [[ "$#" -eq 5 ]] \
                || die "usage: prepare IMAGE IMAGE_ID REVISION RELEASE"
            run_locked prepare "$2" "$3" "$4" "$5"
            ;;
        cutover)
            [[ "$#" -eq 2 ]] || die "usage: cutover RELEASE"
            run_locked cutover "$2"
            ;;
        rollback)
            [[ "$#" -eq 1 ]] || die "usage: rollback"
            run_locked rollback
            ;;
        *)
            die "usage: rtoc-newapi-deploy status|prepare|cutover|rollback"
            ;;
    esac
}

main "$@"
