# grok-free-register 配置模板
# 复制为 .env 后按需修改。未填写的项目会使用程序默认值。

# 邮箱模式
# tempmail: 免费临时邮箱,适合快速试跑。
# moemail: MoeMail OpenAPI,需要 API Key。
# custom: 自建域名邮箱,需要 Cloudflare Email Routing 和本地收信服务。
EMAIL_MODE=tempmail

# moemail 模式专用
# MOEMAIL_API=https://moemail.app
# MOEMAIL_API_KEY=mk_xxx
# MOEMAIL_DOMAIN=moemail.app                 # 留空时自动读取服务端第一个域名
# MOEMAIL_EXPIRY_MS=3600000                  # 1小时;可选 86400000/259200000/0 等

# 输出目录与格式
# legacy 写 accounts.txt/grok.txt;auth-sessions.jsonl 会始终作为自动认证恢复源写入。
# sub/sub2api 和 cpa 会自动调用 xai_enroller 把 SSO 转成 OAuth 后分别写入 keys/sub2api/ 和 keys/cpa/。
# KEY_EXPORT_DIR=keys
# KEY_EXPORT_FORMATS=legacy,sub2api          # legacy | sub2api/sub | cpa
# KEY_EXPORT_ENROLLER=1                      # 0=不自动转换 OAuth
# KEY_EXPORT_ENROLLER_TIMEOUT=1800
# KEY_EXPORT_ENROLLER_POLL_SEC=5
# KEY_EXPORT_ENROLLER_RETRY_ATTEMPTS=0
# KEY_EXPORT_ENROLLER_DRAIN_TIMEOUT=10       # 退出时最多等待导出任务秒数

# 可选:Grok/xAI 代理池。默认读取项目目录下 代理.txt,一行一个 http/socks5 代理。
# 也可填写 vmess/vless/trojan/ss/hy2/hysteria2/tuic/anytls 分享链接,
# 程序会通过本机 proxy-relay 服务导入并转换为本地 HTTP/SOCKS 代理。
# 代理池只用于 accounts.x.ai/xAI/Grok 注册、发码、提交和自动认证转换;MoeMail 等邮箱 HTTP 默认直连。
# 未设置 PROXY_POOL_FILE 且 代理.txt 不存在时,也会兼容读取 proxy.txt。
# PROXY_POOL_FILE=代理.txt
# PROXY_POOL_STRATEGY=round_robin            # round_robin | random
# PROXY_RELAY_ENABLED=1                      # 0=不尝试转换分享链接
# PROXY_RELAY_URL=http://127.0.0.1:18080
# PROXY_RELAY_KERNEL=auto                    # auto | sing-box | xray
# PROXY_RELAY_PROXY_SCHEME=auto              # auto | http | socks5
# PROXY_RELAY_TIMEOUT=8
# PROXY_RELAY_RETRY_SEC=30

# 可选:自动拉取公开节点,多线程测试后把可访问 xAI 的本地代理混入代理池。
# 默认每 20 分钟更新一次;拉取订阅时会轮换使用当前已有代理,不会所有请求挤到同一个代理。
# PROXY_AUTO_FETCH_ENABLED=0
# PROXY_AUTO_FETCH_URLS=                     # 留空时使用内置 NoMoreWalls raw/base64 订阅
# PROXY_AUTO_FETCH_SOURCES_FILE=proxy-sources.txt
# PROXY_AUTO_FETCH_INTERVAL_SEC=1200
# PROXY_AUTO_FETCH_WORKERS=8
# PROXY_AUTO_TEST_WORKERS=16
# PROXY_AUTO_FETCH_TIMEOUT=12
# PROXY_AUTO_TEST_TIMEOUT=10
# PROXY_AUTO_TEST_URLS=https://accounts.x.ai/sign-up?redirect=grok-com
# PROXY_AUTO_TEST_ACCEPT_STATUS=200-399
# PROXY_AUTO_EXPORT_FORMATS=raw,sub2api      # raw | base64 | sub2api | cpa
# PROXY_AUTO_OUTPUT_DIR=logs
# PROXY_AUTO_ACTIVE_FILE=proxy-auto-active.txt
# PROXY_AUTO_STATE_FILE=proxy-auto-state.json
# PROXY_AUTO_SOURCE_LIST_DEPTH=1             # *URL 订阅源列表最多展开层数
# PROXY_AUTO_MAX_CANDIDATES=0                # 0=不限
# PROXY_AUTO_MAX_ACTIVE=0                    # 0=不限
# 公共免费代理/订阅爬取(先 scrape 再交给 proxy_auto 测活)
# PROXY_SCRAPER_SOURCES_FILE=proxy-scraper-sources.txt
# PROXY_SCRAPER_OUT=logs/proxy-scraper-candidates.txt
# PROXY_SCRAPER_WORKERS=12
# PROXY_SCRAPER_TIMEOUT=15
# PROXY_SCRAPER_GITHUB=0                     # 1=GitHub code search(建议 GITHUB_TOKEN)
# GITHUB_TOKEN=
# Go 代理测活加速(bash scripts/build-native.sh)
# PROXY_WORKER_ENGINE=go                     # go|auto|python  (硬性栈要求 go 二进制存在)
# INVENTORY_ENGINE=rust                      # rust|python     (硬性栈要求 inventory-worker)
# INVENTORY_WORKER_BIN=native/inventory-worker/inventory-worker
# PROXY_WORKER_BIN=native/proxy-worker/proxy-worker
# PROXY_WORKER_URL=                          # 例如 http://127.0.0.1:18765
# Web 控制面板: bash start.sh --dashboard
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8787
# CONTROL_PLANE_ALLOW_ACTIONS=0              # 1=允许面板 start/stop/scrape
# 面板访问密码（公网 / HF Space / 0.0.0.0 务必设置）
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=change_me
# 或 API Token：Authorization: Bearer <token>
# CONTROL_PLANE_TOKEN=
# （别名：CONTROL_PLANE_PASSWORD / CONTROL_PLANE_USER / DASHBOARD_TOKEN / PANEL_PASSWORD）

# 可选:外部邮箱 provider 或 xAI HTTP 被 Cloudflare 拦截时用内置 CF-Ares 兜底。
# 本项目已内置 vendor/CF-Ares;这里仅控制是否启用。
# CF_ARES_EMAIL=0                            # 0=关闭;fallback=邮箱 HTTP 遇到拦截时重试;always=始终使用
# CF_ARES_XAI=fallback                       # 0=关闭;fallback=xAI HTTP 失败/拦截时重试;always=始终使用
# CF_ARES_IMPERSONATE=chrome120              # cf-ares wheel 不完整时的 curl_cffi 浏览器指纹
# CF_ARES_BROWSER_ENGINE=auto                # auto | undetected | seleniumbase
# CF_ARES_HEADLESS=1
# CF_ARES_PROXY=                             # 留空时沿用 HTTPS_PROXY/HTTP_PROXY
# CF_ARES_CHROME_PATH=                       # 可选:Chrome/Chromium 路径
# CF_ARES_PATH=                              # 可选:覆盖为其他 CF-Ares 源码目录;默认使用 vendor/CF-Ares
# CF_ARES_TIMEOUT=30

# custom 模式专用
# EMAIL_DOMAIN=example.com
# EMAIL_API=http://127.0.0.1:8080

# 认证账号来源
# auto: 配置 SSH 主机时读取远端，否则读取当前项目；一般保持默认即可。
# XAI_AUTH_SERVICE_SOURCE=auto              # auto | local | ssh
# XAI_AUTH_SERVICE_REGISTER_ROOT=.          # local 模式下的注册项目目录

# 注册与认证不在同一台机器时填写
# XAI_AUTH_SERVICE_SSH_HOST=user@server.example
# XAI_AUTH_SERVICE_SSH_IDENTITY=/path/to/key.pem
# XAI_AUTH_SERVICE_REMOTE_ROOT=/opt/grok-free-register
# XAI_AUTH_SERVICE_SYNC_SEC=30              # 同步新账号的间隔(秒)

# 认证节奏
# XAI_AUTH_SERVICE_MIN_INTERVAL_SEC=10      # 两次认证请求的最小间隔(秒)
# XAI_AUTH_SERVICE_RETRY_SEC=60             # 被限流后的探测间隔(秒)
# XAI_AUTH_SERVICE_LOG_MODE=user            # user | debug

# 运行目标
# TARGET=0                                 # 成功 N 个后停止;0=不限

# 日志显示
# REGISTER_LOG_MODE=user                    # 默认:任务开始、结果、平均速度和限流等待
# REGISTER_LOG_MODE=debug                   # 额外显示 T/Q/并发/阶段耗时调试面板

# 浏览器并发容量
# PHYSICAL_CAP=0                           # 0=按 CPU/内存自动估算;>0=手动指定
# PHYSICAL_PER_CPU=2                       # 自动估算时每个 CPU 核心对应的并发参考值
# PHYSICAL_MEM_MB=512                      # 自动估算时每个浏览器任务的内存预算(MB)
# MIN_FREE_MEM_MB=500                      # 自动估算时保留的内存(MB)
# CAPACITY_PROFILE=                        # 可选:离线压测生成的静态 profile(JSON)

# 缓冲容量
# T_SLOT_CAP=8
# Q_SLOT_CAP=8
# Q_PENDING_CAP=12

# Worker 数量
# 通常不需要手动设置。0 表示根据容量自动派生。
# S_WORKERS=0
# P_WORKERS=0
# C_WORKERS=0

# 资源有效期
# T_MAX_AGE=300                            # token 最大年龄(秒)
# Q_MAX_AGE=120                            # 验证码最大年龄(秒)

# 阶段超时
# P_REQUEST_TIMEOUT=95                     # 等待验证码返回超时(秒)
# EMAIL_CODE_RESEND_ATTEMPTS=2             # 验证码未收到时最多重新发送次数
# EMAIL_CODE_RESEND_AFTER_SEC=35           # 每次等待多久仍未收到才重发
# C_CONSUME_TIMEOUT=60                     # 最终提交阶段超时(秒)

# 局部门控和批量发送
# 这些项目默认会按容量派生。只有在压测定位后才建议覆盖。
# T_TARGET=4                               # token 缓冲目标
# Q_TARGET=4                               # 验证码缓冲目标
# T_HIGH_WATER=                            # token 生产高水位
# T_LOW_WATER=                             # token 生产恢复低水位
# Q_HIGH_WATER=                            # 验证码生产高水位
# Q_LOW_WATER=                             # 验证码生产恢复低水位
# P_BATCH_MAX=4                            # 单个发送页面最多发送的验证码请求数;实际值会按物理并发向下收敛
# P_SEND_CAP=0                             # 0=不额外限制;>0=限制发送页面并发
# REGISTER_HEARTBEAT_INTERVAL=60           # user 日志模式下的运行心跳;0=关闭

# 页面和 token 获取
# SOLVER_REUSE=1                           # token 页面复用
# MAX_SOLVER_REUSE=25                      # 单个 token 页面最大复用次数
# SOLVER_INITIAL_WAIT_MS=500               # token 注入后的首次等待
# SOLVER_POLL_INTERVAL_MS=500              # token 轮询间隔
# SOLVER_POLL_ATTEMPTS=100                 # token 最大轮询次数
# SOLVER_HARD_TIMEOUT=90                    # 单次 solver 全链路硬截止(秒)
# SOLVER_CLEANUP_TIMEOUT=5                  # 异常页回收最长等待(秒)
# SOLVER_FAST_CLICK=1                      # 没有可见验证框时跳过慢点击
# SOLVER_MOUSE_CLICK_RETRIES=3             # token 验证框中心点击次数;0=关闭
# SOLVER_MOUSE_CLICK_INTERVAL_MS=600       # token 中心点击间隔(ms)
# TURNSTILE_SOLVER=d3vin                   # 默认 d3vin;可选 local|theyka|api
#                                          # d3vin/theyka=内置 vendor/turnstile-solver,自动拉起
#                                          # api=外部 REST,或配合 TURNSTILE_SOLVER_ENGINE 用内置
# TURNSTILE_SOLVER_ENGINE=d3vin            # api 模式下的内置引擎:d3vin|theyka|external
# TURNSTILE_API_URL=                       # 留空则按引擎默认端口(d3vin=5072,theyka=5000)
# TURNSTILE_API_MANAGED=1                  # 是否由注册进程自动管理内置 solver
# TURNSTILE_API_TIMEOUT=90                 # API 单次求解超时(秒)
# TURNSTILE_API_POLL_INTERVAL_MS=500       # 轮询 /result 间隔(ms)
# TURNSTILE_API_ACTION=                    # 可选 action 参数
# TURNSTILE_API_CDATA=                     # 可选 cdata 参数
# TURNSTILE_SOLVER_HOST=127.0.0.1          # 内置 solver 监听地址
# TURNSTILE_SOLVER_PORT=                   # 留空用引擎默认
# TURNSTILE_SOLVER_THREADS=2               # 内置 solver 浏览器线程数
# TURNSTILE_SOLVER_BROWSER=chromium        # chromium|chrome|msedge|camoufox
# TURNSTILE_SOLVER_HEADLESS=1              # 无头模式
# TURNSTILE_SOLVER_PROXY=0                 # 是否读取 turnstile-proxies.txt / 工作目录 proxies.txt
# TURNSTILE_SOLVER_AUTO_BROWSER=1          # 首次自动 patchright install
# TURNSTILE_SOLVER_WORK_DIR=logs/turnstile-solver
# PAGE_GOTO_WAIT_UNTIL=domcontentloaded    # 页面导航等待策略
# PAGE_POST_WAIT_MS=500                    # 页面导航后的短等待

# 可选性能开关
# PAGE_BLOCK_STATIC_ASSETS=0               # 阻断部分静态资源,降低页面准备成本
# C_HOT_PAGE_POOL=0                        # 复用消费阶段页面,会增加常驻内存
# C_HOT_PAGE_POOL_SIZE=0                   # 0=按启动期并发派生;>0=手动指定
# C_SET_COOKIE_VIA_REQUEST=1               # 用浏览器 request 访问 set-cookie URL,失败再回退导航

# 代理
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# REGISTER_ENGINE=python                     # python|go  (go 需 register-worker 已编译)
# GO_REGISTER_WORKERS=4
# GO_REGISTER_OUTPUT=keys/accounts.go.txt
# REGISTER_WORKER_BIN=native/register-worker/register-worker
