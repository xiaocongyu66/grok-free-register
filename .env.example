# ============================================================
#  grok-free-register 配置示例
#  复制为 .env 后按需修改;所有项都有默认值,可只填需要的。
# ============================================================

# ── 邮箱模式 ──
# tempmail = 免费临时邮箱(默认,零配置,multi-provider fallback)
# custom   = 自建域名邮箱(需 Cloudflare Email Routing + 本地 webhook,见 README)
EMAIL_MODE=tempmail

# custom 模式专用:
# EMAIL_DOMAIN=example.com               # 你接入 Cloudflare 的域名
# EMAIL_API=http://127.0.0.1:8080        # 本地收信服务(email_server.py)地址

# ── 资源上限(留空=按 CPU 核数自动)──
# MAX_SLOTS=                              # 最大并发浏览器操作数,默认 cpu*4
# CPU_TARGET=85                          # 调速器目标 CPU 利用率(%)
# MIN_FREE_MEM_MB=500                    # 可用内存低于此值(MB)则收缩并发
# T_TARGET=4                             # Turnstile token 缓冲目标
# Q_TARGET=4                             # 验证码缓冲目标
# SOLVER_REUSE=1                         # solver 页面复用(1=开 默认;0=关,用于 A/B 测增益)
# TARGET=0                               # 攒够 N 个号自动停止(0=不限;CLI: --target 100)

# ── 代理(可选,海外直连可不填)──
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
