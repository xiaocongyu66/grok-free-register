# ============================================================
#  grok-free-register 配置示例 (CSP 架构)
#  复制为 .env 后按需修改;所有项都有默认值,可只填需要的。
# ============================================================

# ── 邮箱模式 ──
# tempmail = 免费临时邮箱(默认,零配置,multi-provider fallback)
# custom   = 自建域名邮箱(需 Cloudflare Email Routing + 本地 webhook,见 README)
EMAIL_MODE=tempmail

# custom 模式专用:
# EMAIL_DOMAIN=example.com               # 你接入 Cloudflare 的域名
# EMAIL_API=http://127.0.0.1:8080        # 本地收信服务(email_server.py)地址

# ── CSP 容量参数 ──
# Physical_Sem: 本地物理资源许可(浏览器页面并发)
# PHYSICAL_CAP=0                           # 0=按 CPU/内存静态派生;>0=显式覆盖
# PHYSICAL_PER_CPU=2                       # 自动派生的 CPU 侧保守上限;4 只能作为压测候选
# PHYSICAL_MEM_MB=512                      # 自动派生时每个物理许可的保守内存预算
# CAPACITY_PROFILE=                        # 可选:离线压测生成的启动期静态 profile(JSON)
# T_Slot_Sem: token 库存缓冲容量
# T_SLOT_CAP=8
# Q_Slot_Sem: 验证码库存缓冲容量
# Q_SLOT_CAP=8
# Q_Pending_Sem: 外部在途 Q 请求上限
# Q_PENDING_CAP=12

# ── Worker 数量(0=自动派生,通常不需要手动调) ──
# S_WORKERS=0                              # S_Worker 数: Physical+2
# P_WORKERS=0                              # P_Worker 数: Q_Pending+2
# C_WORKERS=0                              # C_Worker 数: Physical+2

# ── 资源 TTL ──
# T_MAX_AGE=300                            # token 最大年龄(秒)
# Q_MAX_AGE=120                            # 验证码最大年龄(秒)

# ── 阶段超时 ──
# P_REQUEST_TIMEOUT=95                     # P 等待验证码返回超时(秒)
# C_CONSUME_TIMEOUT=60                     # C 消费完整 T/Q pair 超时(秒)

# ── CSP v2 局部门控(高级覆盖项;默认由上面的容量目标派生,通常不逐机器手调) ──
# T_HIGH_WATER=4                           # S 生产高水位,默认 min(T_SLOT_CAP,max(T_TARGET,Physical_Sem))
# T_LOW_WATER=2                            # S 恢复生产低水位,默认 T_HIGH_WATER//2
# Q_HIGH_WATER=12                          # P 在途+库存目标,默认 Q_PENDING_CAP
# Q_LOW_WATER=4                            # P 恢复批量发送低水位,默认 min(Q_TARGET,Q_HIGH_WATER//2)
# P_BATCH_MAX=4                            # 单个 P 发送页面最多批量发码数
# P_SEND_CAP=0                             # 0=不额外限制;>0=显式静态限制并发 P 发送页面

# ── 其它 ──
# SOLVER_REUSE=1                           # solver 页面复用(1=开 默认;0=关)
# MAX_SOLVER_REUSE=25                      # 单个 solver 页面最大复用次数
# SOLVER_INITIAL_WAIT_MS=1500              # solver 注入后首次读取等待
# SOLVER_POLL_INTERVAL_MS=500              # solver token 轮询间隔
# SOLVER_POLL_ATTEMPTS=100                 # solver token 最大轮询次数
# TARGET=0                                 # 攒够 N 个号自动停止(0=不限;CLI: --target 100)

# ── 代理(可选,海外直连可不填) ──
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
